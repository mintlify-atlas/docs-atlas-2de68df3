  "keyFeatures": [
    "Offline speech-to-text with multiple model types (Whisper, Paraformer, Zipformer, etc.)",
    "Real-time streaming speech recognition with partial results",
    "Text-to-speech with multiple voices and languages",
    "Streaming TTS for low-latency audio generation",
    "Voice Activity Detection (VAD)",
    "Speaker diarization for multi-speaker audio",
    "Speech enhancement and noise reduction",
    "Source separation for audio streams",
    "Hardware acceleration support (NNAPI, XNNPACK, Core ML, QNN)",
    "Model quantization support (int8) for smaller footprint",
    "Play Asset Delivery (PAD) support for Android",
    "Automatic model type detection",
    "TypeScript support with full type definitions"
  ],
